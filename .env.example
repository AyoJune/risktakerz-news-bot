# Discord Bot Configuration
DISCORD_TOKEN=your_discord_token_here
ALERTS_CHANNEL_ID=your_alerts_channel_id_here

# News API Configuration (Optional)
NEWS_API_KEY=your_news_api_key_here
ECONOMIC_API_KEY=your_economic_api_key_here

# Other Configuration
BOT_PREFIX=!
BOT_VERSION=0.1.0
TIMEZONE=US/Pacific

# IMPORTANT:
# 1. Get DISCORD_TOKEN from: https://discord.com/developers/applications
# 2. Get ALERTS_CHANNEL_ID by right-clicking Discord channel → Copy Channel ID
# 3. DO NOT commit .env to GitHub - it contains secrets!
# 4. Copy this file to .env and fill in your values
# 5. For Railway: Add these variables via Railway dashboard (Variables tab)
